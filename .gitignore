# ============================================================
# SECURITY: 以下文件绝对不得进入版本库
# ============================================================
*.env
*.env.*
!*.env.example
secrets/
**/*secret*.yaml
**/*secret*.yml
!**/*secret*-template.yaml
*.pem
*.key
*.crt
*.p12
*.jks

# ============================================================
# Java / Maven / Spring Boot
# ============================================================
target/
*.class
*.jar
*.war
!*-sources.jar
.mvn/
!.mvn/wrapper/maven-wrapper.jar
.idea/
*.iml
.project
.classpath
.settings/
.factorypath

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.python-version
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# ============================================================
# Node.js / Vue3 / Vite
# ============================================================
node_modules/
npm-debug.log*
apps/*/dist/
apps/*/dist-ssr/
apps/*/.cache/
apps/*/.vite/

# ============================================================
# 模型文件（通过 MLflow/MinIO 管理，不提交到 Git）
# ============================================================
*.pt
*.pth
*.onnx
*.trt
*.engine
*.plan
*.bin
*.weights
models/

# ============================================================
# 视频和图像原始文件（通过 MinIO 管理）
# ============================================================
*.mp4
*.avi
*.mkv
*.mov
lab-videos/

# ============================================================
# 日志
# ============================================================
*.log
logs/

# ============================================================
# 操作系统 / IDE
# ============================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/
*.swp
*.swo

# ============================================================
# 测试输出
# ============================================================
coverage/
test-results/

# ============================================================
# 临时文件
# ============================================================
*.tmp
*.bak
local/
